# Copy this file to .env and fill in real values. .env is gitignored — never commit real keys.

# ElevenLabs — voiceover + background music
ELEVENLABS_API_KEY=

# Google Gemini — "Nano Banana" image generation (gemini-2.5-flash-image) + script/storyboard text.
# Needs billing enabled on the Google AI Studio project for image generation
# (the free tier quota for gemini-2.5-flash-image is 0).
GEMINI_API_KEY=

# Optional: OpenAI — scene image generation (gpt-image-1). If set, image_gen.py
# tries this before Gemini/Nano Banana, then falls back to a placeholder frame.
OPENAI_API_KEY=

# Optional: YouTube Data API key for faster/richer competitor search.
# If omitted, competitor_analysis.py falls back to yt-dlp (no key needed, slower).
YOUTUBE_API_KEY=
